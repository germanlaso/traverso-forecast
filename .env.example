# ══════════════════════════════════════════════════════════════════
# ARCHIVO DE EJEMPLO — copia esto como .env y completa los valores
# Este archivo SÍ se sube a GitHub (sin valores reales)
# El archivo .env real NUNCA se sube
# ══════════════════════════════════════════════════════════════════

# IP o hostname del servidor SQL Server de ventas
SQL_SERVER=

# Nombre de la base de datos de ventas
SQL_DATABASE=

# Usuario con permisos de solo lectura (SELECT)
SQL_USERNAME=

# Contraseña del usuario
SQL_PASSWORD=

# Driver ODBC (no modificar salvo que uses otro driver)
SQL_DRIVER=ODBC Driver 18 for SQL Server
